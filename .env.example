# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Splitwise API Key (from https://secure.splitwise.com/oauth_clients)
SPLITWISE_API_KEY=your_api_key_here

# Kalash's Splitwise user ID (optional — bot will auto-find if name contains "kalash")
# To find manually: open splitwise.com, go to Kalash's profile, ID is in the URL
SPLITWISE_KALASH_USER_ID=

# Splitwise Group ID (optional — if you want expenses in a specific group)
SPLITWISE_GROUP_ID=

# Set by Render automatically — don't set manually
# RENDER_EXTERNAL_URL=your-app.onrender.com
